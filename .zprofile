#
# Define base environment variables for the ZSH Shell.  The Z shell (ZSH) is
# a Unix shell that can be used as an interactive login shell and as a command
# interpreter for shell scripting.  ZSH is a extendet Bourne-Again Shell (Bash)
# with many improvements, including some features of bash, ksh, and tcsh.
#

# Default
export EDITOR="nvim"
export ZDOTDIR="$HOME/.config/zsh"
